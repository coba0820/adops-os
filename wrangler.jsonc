{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "webapp",
  "compatibility_date": "2026-04-26",
  "pages_build_output_dir": "./dist",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  // AdOps OS: D1データベース（媒体/サイト/キャンペーンマスタ、アップロード履歴を格納）
  // database_id は本番デプロイ前に `wrangler d1 create adops-os-production` で取得し置き換える
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "adops-os-production",
      "database_id": "local-dev-placeholder"
    }
  ]
  // "vars": {
  //   "MY_VAR": "my-variable"
  // },
  // "kv_namespaces": [
  //   {
  //     "binding": "MY_KV_NAMESPACE",
  //     "id": "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  //   }
  // ],
  // "r2_buckets": [
  //   {
  //     "binding": "MY_BUCKET",
  //     "bucket_name": "my-bucket"
  //   }
  // ],
  // "ai": {
  //   "binding": "AI"
  // }
}